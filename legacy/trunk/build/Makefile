	$(MAKE) $(MAKESILENT) -f CMakeFiles\doomlegacy.dir\build.make CMakeFiles/doomlegacy.dir/video/v_video.cpp.i
.PHONY : video/v_video.cpp.i

video/v_video.s: video/v_video.cpp.s
.PHONY : video/v_video.s

# target to generate assembly for a file
video/v_video.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\doomlegacy.dir\build.make CMakeFiles/doomlegacy.dir/video/v_video.cpp.s
.PHONY : video/v_video.cpp.s

